PORT=8080
DATA_DIR=./.data
APP_BASE_URL=http://localhost:8080
APP_ROLE=control-plane
WORKER_STREAM_ID=
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-now
ONVIF_USERNAME=onvif
ONVIF_PASSWORD=change-me-now
SESSION_TTL_HOURS=24
HEALTHCHECK_INTERVAL_SECONDS=120
ONVIF_DISCOVERY_ENABLED=true
ONVIF_DISCOVERY_PORT=3702
GITHUB_URL=https://github.com/itsh-neumeier/UbiRSTP2ONVIF

# Worker template hints for compose generators or overlays
# These values are documentation helpers for a one-camera-per-IP deployment.
WORKER_NAME=cam-01
WORKER_ADVERTISED_IP=192.168.10.201
WORKER_HTTP_PORT=8080
WORKER_NETWORK_MODE=macvlan
WORKER_ENABLE_DISCOVERY=true

# go2rtc sidecar hints
GO2RTC_RTSP_PORT=8554
GO2RTC_API_PORT=1984
GO2RTC_CONFIG_PATH=/config/go2rtc.yaml

# Optional advanced media transforms
GO2RTC_PIPELINE=
FFMPEG_TRANSFORM_CHAIN=
